++ hostname
+ HOSTNAME=tartu
++ pos_get_variable --from-loop implementation
+ IMPLEMENTATION=lsquic
++ pos_get_variable --from-global nodes/tartu/interfaces
++ grep -oP ''\''name'\'': '\''\K[^'\'']+'
++ head -1
+ IFNAME=enp2s0f0
+ DL_DIR=/root/downloads
+ LOG_DIR=/root/logs
+ DLPATH=/testfile
+ REQ=https://server:4433/testfile
+ SSLKEYLOGFILE=/root/logs/keys.log
+ VALID_IMPLS=("quiche" "tquic" "lsquic" "picoquic" "aioquic" "quic-go")
+ DEFAULT_IMPL=quiche
+ [[ !  quiche tquic lsquic picoquic aioquic quic-go  =~  lsquic  ]]
+ mkdir -p /root/downloads
+ mkdir -p /root/logs
+ echo 'Client started, waiting for server to be ready...'
+ pos_sync --tag server_ready
+ echo 'Server ready, starting client...'
